<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans
        https://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        ============================================================
        Handbook 3 – employee.xml
        "Create static employee list data using spring xml configuration"
        ============================================================

        Structure:
          Skill beans     – reusable skills referenced by employees
          Department beans – two or more departments as required
          Employee beans   – four employee instances using sample data
          employeeList     – ArrayList containing all four employees
          departmentList   – ArrayList containing all departments

        Spring XML property injection calls the setter for each <property>.
        <ref bean="..."/> injects another bean by its id (dependency injection).
        <list> inside a property creates a java.util.ArrayList for that field.
    -->

    <!-- ===== SKILL BEANS ===== -->
    <bean id="skillJava" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="1" />
        <property name="name" value="Java" />
    </bean>

    <bean id="skillSpring" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="2" />
        <property name="name" value="Spring" />
    </bean>

    <bean id="skillAngular" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="3" />
        <property name="name" value="Angular" />
    </bean>

    <bean id="skillReact" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="4" />
        <property name="name" value="React" />
    </bean>

    <bean id="skillSQL" class="com.cognizant.springlearn.model.Skill">
        <property name="id" value="5" />
        <property name="name" value="SQL" />
    </bean>

    <!-- ===== DEPARTMENT BEANS ===== -->
    <!-- Handbook 3: "Create one or two more departments" -->
    <bean id="deptIT" class="com.cognizant.springlearn.model.Department">
        <property name="id" value="1" />
        <property name="name" value="Information Technology" />
    </bean>

    <bean id="deptHR" class="com.cognizant.springlearn.model.Department">
        <property name="id" value="2" />
        <property name="name" value="Human Resources" />
    </bean>

    <bean id="deptFinance" class="com.cognizant.springlearn.model.Department">
        <property name="id" value="3" />
        <property name="name" value="Finance" />
    </bean>

    <!-- ===== EMPLOYEE BEANS ===== -->
    <!--
        Handbook 3: "Create four more instances of Employee.
                     Reuse existing skills instead of creating new ones."
        Employee sample data matches the Angular module employee list.
        Skills are referenced with <ref bean="..."/> to reuse the same bean instances.
    -->
    <bean id="emp1" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="1" />
        <property name="name" value="Alice Johnson" />
        <property name="salary" value="75000" />
        <property name="permanent" value="true" />
        <property name="dateOfBirth" value="15/03/1990" />
        <property name="department" ref="deptIT" />
        <property name="skills">
            <list>
                <ref bean="skillJava" />
                <ref bean="skillSpring" />
            </list>
        </property>
    </bean>

    <bean id="emp2" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="2" />
        <property name="name" value="Bob Smith" />
        <property name="salary" value="65000" />
        <property name="permanent" value="true" />
        <property name="dateOfBirth" value="22/07/1988" />
        <property name="department" ref="deptIT" />
        <property name="skills">
            <list>
                <ref bean="skillAngular" />
                <ref bean="skillReact" />
            </list>
        </property>
    </bean>

    <bean id="emp3" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="3" />
        <property name="name" value="Carol Williams" />
        <property name="salary" value="55000" />
        <property name="permanent" value="false" />
        <property name="dateOfBirth" value="10/11/1995" />
        <property name="department" ref="deptHR" />
        <property name="skills">
            <list>
                <ref bean="skillSQL" />
            </list>
        </property>
    </bean>

    <bean id="emp4" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="4" />
        <property name="name" value="David Brown" />
        <property name="salary" value="80000" />
        <property name="permanent" value="true" />
        <property name="dateOfBirth" value="05/06/1985" />
        <property name="department" ref="deptFinance" />
        <property name="skills">
            <list>
                <ref bean="skillJava" />
                <ref bean="skillSQL" />
            </list>
        </property>
    </bean>

    <!--
        Handbook 3: "Include all four employee instances in an ArrayList"
        EmployeeDao reads this bean at startup and stores it in EMPLOYEE_LIST.
    -->
    <bean id="employeeList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="emp1" />
                <ref bean="emp2" />
                <ref bean="emp3" />
                <ref bean="emp4" />
            </list>
        </constructor-arg>
    </bean>

    <!--
        Handbook 3: DepartmentDao reads this list for GET /departments.
    -->
    <bean id="departmentList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="deptIT" />
                <ref bean="deptHR" />
                <ref bean="deptFinance" />
            </list>
        </constructor-arg>
    </bean>

</beans>
